{
  "name": "garment-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "sync:clickup": "node --experimental-strip-types scripts/run-clickup-import.mjs",
    "db:migrate-json": "node scripts/migrate-json-to-supabase.mjs",
    "db:sync-from-supabase": "echo 'WARNING: supplier_contacts sync preserves required fabric suppliers from local — stale Supabase cannot drop solbiati/canclini/wool-stock.' && node scripts/sync-documents-from-supabase.mjs",
    "db:seed-canclini": "node --experimental-strip-types --import ./scripts/tsconfig-paths-loader.mjs scripts/seed-canclini-inventory.mjs",
    "db:archive-fabric-receipts": "node scripts/archive-historical-fabric-receipts.mjs",
    "drapers:sync-stock": "node --experimental-strip-types --import ./scripts/tsconfig-paths-loader.mjs scripts/sync-drapers-stock.mjs --open-orders",
    "verify:fabric-reset": "node scripts/verify-fabric-receiving-reset.mjs",
    "audit:document-loads": "node scripts/audit-document-loads.mjs",
    "db:types": "supabase gen types typescript --local > src/lib/types/database.generated.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "imapflow": "^1.3.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "sharp": "^0.34.2",
    "lucide-react": "^0.511.0",
    "mailparser": "^3.9.8",
    "next": "^15.3.3",
    "nodemailer": "^8.0.9",
    "pdf-parse": "^2.4.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.15.29",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
