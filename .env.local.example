# Public URL of the deployed ERP (not localhost). Use a subdomain so hagan.pro stays your main site.
# NEXT_PUBLIC_APP_URL=https://erp.hagan.pro

# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (sb_publishable_…) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Comma-separated emails with admin privileges (sales order delete, etc.)
# SUPER_ADMIN_EMAILS are always treated as admins.
SUPER_ADMIN_EMAILS=admin@factory.com,info@hagan.pro
# Optional extra admins until roles are configured in Supabase profiles:
# ADMIN_EMAILS=production@factory.com,orders@factory.com

# Restricted users — clients + fabric specs only; no client email/mobile or fabric list prices
# Built-in QC email (hagan.qc@gmail.com) works without this env var.
# CLIENT_MANAGER_EMAILS=hagan.qc@gmail.com

# Production-floor task operators — print labels/A4 and wash/iron scan only; no prices
# Built-in email (hagan.task1@gmail.com) works without this env var.
# TASK_OPERATOR_EMAILS=hagan.task1@gmail.com

# Factory managers — production floor dashboard; watch wash/iron; advance cut→finish→driver; no prices/accounting
# Built-in email (production@hagan.pro) works without this env var.
# PRODUCTION_EMAILS=production@hagan.pro

# Tablet sales users — client/catalog/order/invoice/fitting access; no purchasing costs or internal production detail
# SALES_EMAILS=sales1@factory.com,sales2@factory.com
# Per-sales brand lock (optional). Format: email:brand or email:brand1|brand2,email2:brand3
# SALES_BRAND_SCOPE=sales1@factory.com:gliani,sales2@factory.com:fouad|fouad-rahme

# Optional — required for Supabase document storage + migration script (Settings → API → secret key)
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─── Supabase Auth resilience (GitHub Actions cron + auto-restart) ─
# See docs/supabase-auth-resilience.md
# CRON_SECRET=generate-with-openssl-rand-hex-32  (Vercel + GitHub Actions secret)
# SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token
# SUPABASE_PROJECT_REF=your-project-ref

# Force local JSON files even when Supabase is configured (debug / offline)
# ERP_USE_JSON=true

# Comma-separated codes to reveal fabric prices and cost on sales orders (admins only; cookie unlock, 12h).
# Built-in password 1122 always works without this env. Set FABRIC_PRICE_ACCESS_CODES to add more codes.
# Also accepts INVOICE_AMOUNTS_PASSWORD if set (e.g. 123456789). Prices stay hidden until unlocked.
# FABRIC_PRICE_ACCESS_CODES=1122

# Password to reveal Outstanding / Paid totals on the Invoicing tab (session-only, per browser tab).
# If already set on Vercel, fabric price unlock accepts this password too (no separate code needed).
# INVOICE_AMOUNTS_PASSWORD=123456789

# ─── Send fabric orders (orders.ruh@hagan.pro) ───────────────────
# Required for in-app "Direct send" on supplier emails.
# Local dev: set SMTP_PASS here OR paste password in Purchasing → Supplier Emails (saved to smtp-secret.local.json).
# Production (Vercel): add ALL of these in Project Settings → Environment Variables, then redeploy.
#   SMTP_PASS must be set on Vercel — the UI password field does not persist on serverless.
# Microsoft 365 (@hagan.pro): smtp.office365.com, port 587, SMTP_SECURE=false, Authenticated SMTP enabled.
# Google Workspace: smtp.gmail.com, port 587, SMTP_SECURE=false, use an App Password (not your login password).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=orders.ruh@hagan.pro
SMTP_PASS=your-mailbox-password
SMTP_FROM=orders.ruh@hagan.pro
SMTP_FROM_NAME=Hagan Fabric Orders

# ─── Scan supplier replies + AWB (IMAP) ──────────────────────────
# Override inbox_scan_email from Purchasing → Suppliers, or set here:
# Google App Password: https://myaccount.google.com/apppasswords
IMAP_USER=your-scan-inbox@gmail.com
IMAP_PASS=your-gmail-app-password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true

# Optional inbox scan depth (defaults: 180 days, 400 recent emails + all supplier senders)
# INBOX_SCAN_DAYS=180
# INBOX_SCAN_LIMIT=400

ERP_API_KEY=your-secret-api-key
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/xxxxx/

# ─── SAR conversion (book rates for display) ─────────────────────
# EUR_TO_SAR=4.5
# USD_TO_SAR=3.75
# EUR_SAR_ALERT_THRESHOLD=4.5

# ─── ClickUp import (Hagan workspace) ───────────────────────────
# Personal API token: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=pk_your_clickup_token

# ─── Drapers Italy API (v2026.1 — https://api.drapersitaly.it/) ───
# Access Key from Company Area → API Integration tab
DRAPERS_API_KEY=your-drapers-access-key
# DRAPERS_API_BASE_URL=https://api.drapersitaly.it

# ─── Caccioppoli API (GR Sistemi — https://api-service.grsis.it/) ───
# Bearer token from Caccioppoli / GR Sistemi (one per client account, e.g. RALPH RHAME)
CACCIOPPOLI_API_TOKEN=your-caccioppoli-bearer-token
# CACCIOPPOLI_API_BASE_URL=https://api-service.grsis.it

# ─── 17TRACK live AWB status + location ─────────────────────────
# API key: https://user.17track.net → API settings
TRACK17_API_KEY=your-17track-api-key
# Webhook (optional, for automatic pushes): https://YOUR-DOMAIN/api/webhooks/17track
