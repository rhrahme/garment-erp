# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (sb_publishable_…) or legacy anon JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Comma-separated emails with super-admin privileges (client delete, etc.)
SUPER_ADMIN_EMAILS=admin@factory.com,info@hagan.pro

# ─── Send fabric orders (orders.ruh@hagan.pro) ───────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=orders.ruh@hagan.pro
SMTP_PASS=your-mailbox-password
SMTP_FROM=orders.ruh@hagan.pro
SMTP_FROM_NAME=Hagan Fabric Orders

# ─── Scan supplier replies + AWB (IMAP) ──────────────────────────
# Override inbox_scan_email from Purchasing → Suppliers, or set here:
# Google App Password: https://myaccount.google.com/apppasswords
IMAP_USER=your-scan-inbox@gmail.com
IMAP_PASS=your-gmail-app-password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true

# Optional inbox scan depth (defaults: 180 days, 400 recent emails + all supplier senders)
# INBOX_SCAN_DAYS=180
# INBOX_SCAN_LIMIT=400

ERP_API_KEY=your-secret-api-key
ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxxxx/xxxxx/

# ─── SAR conversion (book rates for display) ─────────────────────
# EUR_TO_SAR=4.5
# USD_TO_SAR=3.75
# EUR_SAR_ALERT_THRESHOLD=4.5

# ─── ClickUp import (Hagan workspace) ───────────────────────────
# Personal API token: https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=pk_your_clickup_token

# ─── 17TRACK live AWB status + location ─────────────────────────
# API key: https://user.17track.net → API settings
TRACK17_API_KEY=your-17track-api-key
# Webhook (optional, for automatic pushes): https://YOUR-DOMAIN/api/webhooks/17track
